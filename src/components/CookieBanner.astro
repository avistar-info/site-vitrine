---
import { ANALYTICS } from "../config/site";
// Config passée au script client via un bloc de données JSON (non exécutable,
// conforme à une CSP script-src stricte sans 'unsafe-inline'). Le script de
// consentement ci-dessous est bundlé par Astro (fichier externe servi en 'self').
const cfg = JSON.stringify({ gaId: ANALYTICS.ga4Id, phKey: ANALYTICS.posthogKey, phHost: ANALYTICS.posthogHost });
---
<script type="application/json" id="stela-analytics" set:html={cfg} />

{/* Bannière de consentement minimale. Progressive enhancement : le contenu du
    site fonctionne sans JavaScript ; la mesure d'audience (GA4 + PostHog) ne se
    charge QU'APRÈS acceptation explicite (Google Consent Mode v2). */}
<div id="cookie-banner" class="cookie-banner" hidden>
  <p>Nous utilisons des mesures d'audience pour améliorer le site. Vous pouvez les accepter ou les refuser.</p>
  <div class="cookie-actions">
    <button type="button" data-consent="denied" class="btn btn-ghost">Refuser</button>
    <button type="button" data-consent="granted" class="btn btn-primary">Accepter</button>
  </div>
</div>

<script>
  // Bundlé par Astro (servi en 'self' depuis /_astro/) : compatible CSP stricte.
  const KEY = "stela-consent";
  const cfgEl = document.getElementById("stela-analytics");
  const cfg = cfgEl ? JSON.parse(cfgEl.textContent || "{}") : {};
  const banner = document.getElementById("cookie-banner");

  // Google Consent Mode v2 : défaut « denied » avant tout chargement.
  (window as any).dataLayer = (window as any).dataLayer || [];
  function gtag(...args: unknown[]) { (window as any).dataLayer.push(args); }
  gtag("consent", "default", {
    ad_storage: "denied", analytics_storage: "denied",
    ad_user_data: "denied", ad_personalization: "denied",
  });

  let gaLoaded = false, phLoaded = false;
  function loadTrackers() {
    if (cfg.gaId && !gaLoaded) {
      gaLoaded = true;
      gtag("consent", "update", { analytics_storage: "granted" });
      const s = document.createElement("script");
      s.async = true; s.src = "https://www.googletagmanager.com/gtag/js?id=" + cfg.gaId;
      document.head.appendChild(s);
      gtag("js", new Date());
      gtag("config", cfg.gaId, { anonymize_ip: true });
    }
    if (cfg.phKey && !phLoaded) {
      phLoaded = true;
      const p = document.createElement("script");
      p.async = true; p.src = cfg.phHost + "/static/array.js";
      p.addEventListener("load", () => {
        const ph = (window as any).posthog;
        if (ph && ph.init) ph.init(cfg.phKey, { api_host: cfg.phHost });
      });
      document.head.appendChild(p);
    }
  }

  if (banner) {
    let choice: string | null = null;
    try { choice = localStorage.getItem(KEY); } catch {}
    if (choice === "granted") {
      loadTrackers();
    } else if (choice !== "denied") {
      banner.hidden = false;
      banner.addEventListener("click", (ev) => {
        const t = ev.target as HTMLElement;
        const val = t?.dataset?.consent;
        if (!val) return;
        try { localStorage.setItem(KEY, val); } catch {}
        banner.hidden = true;
        if (val === "granted") loadTrackers();
      });
    }
  }
</script>

<style>
  .cookie-banner { position: fixed; left: 16px; right: 16px; bottom: 16px; z-index: 80; margin-inline: auto;
    max-width: 720px; background: var(--surface); border: 1px solid var(--border); border-radius: 14px;
    box-shadow: var(--shadow); padding: 1rem 1.25rem; display: flex; gap: 1rem; align-items: center;
    justify-content: space-between; flex-wrap: wrap; }
  .cookie-banner p { margin: 0; font-size: .9rem; color: var(--text-secondary); flex: 1 1 320px; }
  .cookie-actions { display: flex; gap: .6rem; }
  .cookie-actions .btn { padding: .6rem 1.1rem; font-size: .92rem; }
</style>
