---
import { ANALYTICS } from "../config/site";
---
{/* Bannière de consentement minimale. Progressive enhancement : le contenu du
    site fonctionne sans JavaScript ; la mesure d'audience (GA4 + PostHog) ne se
    charge QU'APRÈS acceptation explicite (Google Consent Mode v2). */}
<div id="cookie-banner" class="cookie-banner" hidden>
  <p>
    Nous utilisons des mesures d'audience pour améliorer le site. Vous pouvez les accepter ou les refuser.
  </p>
  <div class="cookie-actions">
    <button type="button" data-consent="denied" class="btn btn-ghost">Refuser</button>
    <button type="button" data-consent="granted" class="btn btn-primary">Accepter</button>
  </div>
</div>

<script is:inline define:vars={{ posthogKey: ANALYTICS.posthogKey, posthogHost: ANALYTICS.posthogHost }}>
  (function () {
    var KEY = "stela-consent";
    var banner = document.getElementById("cookie-banner");
    if (!banner) return;

    function loadTrackers() {
      if (window.__gaId && !window.__gaLoaded) {
        window.__gaLoaded = true;
        if (window.gtag) window.gtag("consent", "update", { analytics_storage: "granted" });
        var s = document.createElement("script");
        s.async = true;
        s.src = "https://www.googletagmanager.com/gtag/js?id=" + window.__gaId;
        document.head.appendChild(s);
        window.gtag("js", new Date());
        window.gtag("config", window.__gaId, { anonymize_ip: true });
      }
      // PostHog : chargé seulement si une clé est fournie.
      if (posthogKey && !window.__phLoaded) {
        window.__phLoaded = true;
        !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once unregister identify".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
        window.posthog.init(posthogKey, { api_host: posthogHost });
      }
    }

    var choice = null;
    try { choice = localStorage.getItem(KEY); } catch (e) {}
    if (choice === "granted") { loadTrackers(); return; }
    if (choice === "denied") { return; }

    banner.hidden = false;
    banner.addEventListener("click", function (ev) {
      var t = ev.target;
      if (!t || !t.dataset || !t.dataset.consent) return;
      var val = t.dataset.consent;
      try { localStorage.setItem(KEY, val); } catch (e) {}
      banner.hidden = true;
      if (val === "granted") loadTrackers();
    });
  })();
</script>

<style>
  .cookie-banner { position: fixed; left: 16px; right: 16px; bottom: 16px; z-index: 80; margin-inline: auto;
    max-width: 720px; background: var(--surface); border: 1px solid var(--border); border-radius: 14px;
    box-shadow: var(--shadow); padding: 1rem 1.25rem; display: flex; gap: 1rem; align-items: center;
    justify-content: space-between; flex-wrap: wrap; }
  .cookie-banner p { margin: 0; font-size: .9rem; color: var(--text-secondary); flex: 1 1 320px; }
  .cookie-actions { display: flex; gap: .6rem; }
  .cookie-actions .btn { padding: .6rem 1.1rem; font-size: .92rem; }
</style>
