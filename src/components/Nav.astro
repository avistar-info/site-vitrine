---
import { SITE, NAV_LINKS } from "../config/site";
import Logo from "./Logo.astro";
---
<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label={`${SITE.brand}, accueil`}><Logo /></a>

    {/* Menu en <details> : fonctionne sans JavaScript (disclosure natif). */}
    <details class="nav-disclosure">
      <summary aria-label="Ouvrir le menu"><span></span></summary>
      <nav class="nav-links" aria-label="Navigation principale">
        {NAV_LINKS.map((l) => <a href={l.href}>{l.label}</a>)}
        <a class="btn btn-primary nav-cta" href={SITE.appUrl}>Essayer gratuitement</a>
      </nav>
    </details>
  </div>
</header>
<style>
  .nav { position: sticky; top: 0; z-index: 50; background: rgba(247, 244, 239, .88);
    backdrop-filter: saturate(150%) blur(8px); border-bottom: 1px solid var(--border); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; min-height: 68px; }
  .nav-logo:hover { text-decoration: none; }
  .nav-links { display: flex; align-items: center; gap: 1.5rem; }
  .nav-links a { font-weight: 600; color: var(--text-secondary); }
  .nav-links a:hover { color: var(--ink); text-decoration: none; }
  .nav-links .nav-cta { color: #fff; }
  .nav-disclosure summary { list-style: none; cursor: pointer; display: none; }
  .nav-disclosure summary::-webkit-details-marker { display: none; }

  @media (max-width: 820px) {
    .nav-disclosure summary { display: inline-flex; width: 40px; height: 40px; align-items: center; justify-content: center;
      border: 1px solid var(--border); border-radius: 10px; background: var(--surface); }
    .nav-disclosure summary span,
    .nav-disclosure summary span::before,
    .nav-disclosure summary span::after { display: block; width: 18px; height: 2px; background: var(--ink); position: relative; }
    .nav-disclosure summary span::before { content: ""; position: absolute; top: -6px; }
    .nav-disclosure summary span::after { content: ""; position: absolute; top: 6px; }
    .nav-links { position: absolute; right: 20px; left: 20px; top: 64px; flex-direction: column; align-items: stretch;
      gap: .75rem; background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 1rem; box-shadow: var(--shadow); }
    .nav-links a { padding: .5rem; }
  }
</style>
