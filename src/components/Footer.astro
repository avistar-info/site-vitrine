---
import { SITE } from "../config/site";
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <Logo textColor="#F7F4EF" />
      <p class="footer-tagline">{SITE.tagline}</p>
      <p class="footer-pos">{SITE.positioning}</p>
    </div>
    <nav class="footer-col" aria-label="Produit">
      <h3>Produit</h3>
      <a href="/#fonctionnalites">Fonctionnalités</a>
      <a href="/#tarifs">Tarifs</a>
      <a href="/#conformite">Conformité Google</a>
      <a href={SITE.appUrl}>Essayer gratuitement</a>
    </nav>
    <nav class="footer-col" aria-label="Légal et contact">
      <h3>Contact</h3>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <a href="/mentions-legales">Mentions légales</a>
      <a href="/politique-confidentialite">Confidentialité</a>
      <a href="/cgv">CGV</a>
    </nav>
  </div>
  <div class="container footer-legal">
    <p>© {year} {SITE.brand}. Collecte d'avis 100 % conforme aux règles de Google.</p>
  </div>
</footer>
<style>
  .footer { background: var(--ink); color: #cdd5e4; margin-top: 2rem; }
  .footer-inner { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 2.5rem; padding-block: 3.5rem 2rem; }
  .footer-tagline { color: #F7F4EF; font-weight: 600; margin: .9rem 0 .4rem; }
  .footer-pos { color: #9fb0cc; font-size: .95rem; max-width: 34ch; }
  .footer-col h3 { color: #F7F4EF; font-size: .95rem; margin-bottom: .9rem; }
  .footer-col a { display: block; color: #cdd5e4; padding: .28rem 0; font-size: .95rem; }
  .footer-col a:hover { color: #fff; }
  .footer-legal { border-top: 1px solid rgba(255,255,255,.12); padding-block: 1.25rem; }
  .footer-legal p { color: #8ea0bd; font-size: .85rem; margin: 0; }
  @media (max-width: 720px) { .footer-inner { grid-template-columns: 1fr; gap: 1.75rem; } }
</style>
