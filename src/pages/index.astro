---
import Base from "../layouts/Base.astro";
import { SITE, PLANS } from "../config/site";
import { FEATURES } from "../content/features";

// Maillage : les cartes de la home pointent vers les pages fonctionnalités
// dédiées (source unique content/features.ts).
const features = FEATURES.map((f) => ({ slug: f.slug, t: f.navLabel, d: f.benefits[0].d }));

const faq = [
  {
    q: "Stela filtre-t-il les avis négatifs ?",
    a: "Non. Stela invite tous vos clients à laisser un avis public sur Google, quelle que soit leur satisfaction. Filtrer les avis selon la note est contraire aux règles de Google : Stela ne le fait jamais.",
  },
  {
    q: "Combien coûte Stela ?",
    a: "Deux offres transparentes : Étoile à 49 € par mois et Constellation à 89 € par mois. L'abonnement annuel revient à deux mois offerts. L'essai est gratuit et sans engagement.",
  },
  {
    q: "Pour quels commerces ?",
    a: "Tous les commerces locaux : restaurants, coiffeurs, instituts, garages, hôtels, santé. Le paramétrage s'adapte à votre secteur.",
  },
  {
    q: "Comment commencer ?",
    a: "Vous créez votre compte sur l'application, vous connectez votre fiche Google et vous êtes prêt. Aucune démonstration obligatoire, aucune carte requise pour essayer.",
  },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.brand,
  url: SITE.url,
  inLanguage: "fr-FR",
  publisher: { "@type": "Organization", name: SITE.brand },
};
---

<Base
  title="Stela | Le moteur de croissance Google conforme des commerces locaux"
  description="Collecte d'avis Google 100 % conforme, réponses IA, réservation et fidélisation pour tous les commerces locaux. Prix transparents, essai gratuit."
  path="/"
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />

  {/* HERO */}
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">100 % conforme aux règles de Google</p>
        <h1>{SITE.positioning}</h1>
        <p class="lead">
          Collectez plus d'avis, répondez automatiquement et faites revenir vos clients. Sans filtrer une seule note, parce que la conformité est notre force.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={SITE.appUrl}>Essayer gratuitement</a>
          <a class="btn btn-ghost" href="#tarifs">Voir les tarifs</a>
        </div>
        <p class="hero-trust">Prix transparents. Essai sans engagement. Aucune carte requise.</p>
      </div>
      {/* Emplacement réservé à la vidéo produit incarnée (VIT-5). */}
      <div class="hero-media" aria-hidden="true">
        <div class="hero-media-inner">
          <span class="hero-media-label">Aperçu produit</span>
        </div>
      </div>
    </div>
  </section>

  {/* PREUVE (neutre, sans chiffre non sourcé) */}
  <section class="proof">
    <div class="container">
      <p class="proof-line">Pensé pour tous les commerces locaux : restaurants, coiffeurs, instituts, garages, hôtels, santé.</p>
    </div>
  </section>

  {/* FONCTIONNALITÉS */}
  <section id="fonctionnalites">
    <div class="container">
      <p class="eyebrow">Ce que fait Stela</p>
      <h2>Tout pour votre réputation locale, au même endroit</h2>
      <div class="grid-3">
        {features.map((f) => (
          <a class="card feature-card" href={`/${f.slug}`}>
            <h3>{f.t}</h3>
            <p>{f.d}</p>
            <span class="feature-more">Découvrir</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* CONFORMITÉ (différenciateur) */}
  <section id="conformite" class="conformite">
    <div class="container conformite-grid">
      <div>
        <p class="eyebrow">Notre différence</p>
        <h2>La conformité n'est pas une option, c'est le moteur</h2>
        <p>
          Certains outils trient les clients et détournent les avis négatifs. C'est interdit par Google et cela met votre fiche en danger. Stela fait l'inverse : tous vos clients sont invités à s'exprimer publiquement, et la récupération se fait en plus, jamais à la place.
        </p>
        <ul class="check-list">
          <li>Aucun filtrage des avis selon la note.</li>
          <li>Aucune interception des clients insatisfaits.</li>
          <li>Conforme aux règles de Google et au RGPD.</li>
        </ul>
      </div>
      <div class="card conformite-card">
        <p class="quote">« Tous les avis sont les bienvenus. »</p>
        <p class="quote-sub">Le principe qui protège votre fiche Google sur le long terme.</p>
      </div>
    </div>
  </section>

  {/* TARIFS (toggle mensuel/annuel, 100 % CSS, fonctionne sans JS) */}
  <section id="tarifs" class="tarifs">
    <div class="container">
      <p class="eyebrow">Tarifs transparents</p>
      <h2>Un prix affiché, un essai gratuit, sans engagement</h2>

      <div class="billing-toggle">
        <input type="checkbox" id="billing" class="billing-input" />
        <label for="billing" class="billing-switch">
          <span class="opt opt-m">Mensuel</span>
          <span class="opt opt-y">Annuel <span class="save">2 mois offerts</span></span>
          <span class="knob" aria-hidden="true"></span>
        </label>
      </div>

      <div class="grid-plans">
        {PLANS.map((p) => (
          <div class={`card plan${p.highlight ? " plan-hl" : ""}`}>
            {p.highlight && <span class="plan-badge">Le plus complet</span>}
            <h3 class="plan-name">{p.name}</h3>
            <p class="plan-tag">{p.tagline}</p>
            <p class="plan-price">
              <span class="amount amount-m">{p.monthly} €</span>
              <span class="amount amount-y">{p.yearlyPerMonth} €</span>
              <span class="per">/ mois</span>
            </p>
            <p class="plan-note plan-note-y">Facturé annuellement, soit deux mois offerts.</p>
            <ul class="check-list">
              {p.features.map((f) => <li>{f}</li>)}
            </ul>
            <a class={`btn ${p.highlight ? "btn-primary" : "btn-ghost"} plan-cta`} href={SITE.appUrl}>Essayer gratuitement</a>
          </div>
        ))}
      </div>
      <p class="tarifs-foot">Le paiement se fait en toute sécurité dans l'application, après la création de votre compte.</p>
    </div>
  </section>

  {/* Q&A citable (aligné sur le schema FAQPage) */}
  <section class="faq">
    <div class="container">
      <p class="eyebrow">Questions fréquentes</p>
      <h2>Ce qu'il faut savoir</h2>
      <div class="faq-list">
        {faq.map((f) => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA final */}
  <section class="cta-final">
    <div class="container">
      <h2>Prêt à faire grandir votre réputation, en toute conformité ?</h2>
      <a class="btn btn-primary" href={SITE.appUrl}>Essayer gratuitement</a>
    </div>
  </section>
</Base>

<style>
  .hero { background: linear-gradient(180deg, #fff 0%, var(--cream) 100%); }
  .hero-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: 3rem; align-items: center; }
  .hero-cta { display: flex; gap: .75rem; flex-wrap: wrap; margin: 1.75rem 0 1rem; }
  .hero-trust { font-size: .9rem; color: var(--text-muted); margin: 0; }
  .hero-media-inner { aspect-ratio: 4/3; border-radius: var(--radius); border: 1px solid var(--border);
    background: repeating-linear-gradient(135deg, #fff, #fff 12px, #faf7f1 12px, #faf7f1 24px);
    display: grid; place-items: center; box-shadow: var(--shadow); }
  .hero-media-label { color: var(--text-muted); font-weight: 600; font-size: .9rem; }
  @media (max-width: 820px) { .hero-grid { grid-template-columns: 1fr; } .hero-media { display: none; } }

  .proof { background: var(--ink); }
  .proof { padding-block: 1.25rem; }
  .proof-line { color: #cdd5e4; text-align: center; margin: 0; font-weight: 600; }

  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2rem; }
  @media (max-width: 860px) { .grid-3 { grid-template-columns: 1fr; } }
  .feature-card { display: flex; flex-direction: column; color: inherit; transition: transform .15s ease, box-shadow .15s ease; }
  .feature-card:hover { text-decoration: none; transform: translateY(-2px); box-shadow: 0 10px 30px rgba(21,35,63,.1); }
  .feature-card h3 { color: var(--ink); }
  .feature-more { margin-top: auto; padding-top: .75rem; color: var(--brass); font-weight: 700; font-size: .9rem; }
  .feature-more::after { content: " \2192"; }

  .conformite { background: #fff; }
  .conformite-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 2.5rem; align-items: center; }
  @media (max-width: 860px) { .conformite-grid { grid-template-columns: 1fr; } }
  .conformite-card { background: var(--ink); color: #F7F4EF; }
  .conformite-card .quote { font-size: 1.4rem; font-weight: 800; color: #fff; margin-bottom: .5rem; }
  .conformite-card .quote-sub { color: #9fb0cc; margin: 0; }

  .check-list { list-style: none; padding: 0; margin: 1rem 0 0; }
  .check-list li { position: relative; padding-left: 1.6rem; margin-bottom: .5rem; color: var(--text-secondary); }
  .check-list li::before { content: "✓"; position: absolute; left: 0; color: var(--brass); font-weight: 800; }

  /* Tarifs */
  .tarifs { background: var(--cream); }
  .billing-toggle { display: flex; justify-content: center; margin: 1.5rem 0 2rem; }
  .billing-input { position: absolute; opacity: 0; pointer-events: none; }
  .billing-switch { position: relative; display: inline-flex; align-items: center; gap: .25rem;
    background: #fff; border: 1px solid var(--border); border-radius: 999px; padding: 4px; cursor: pointer; user-select: none; }
  .billing-switch .opt { position: relative; z-index: 1; padding: .5rem 1rem; border-radius: 999px; font-weight: 700; font-size: .92rem; color: var(--text-secondary); }
  .billing-switch .knob { position: absolute; z-index: 0; top: 4px; bottom: 4px; left: 4px; width: calc(50% - 4px);
    background: var(--ink); border-radius: 999px; transition: transform .2s ease; }
  .billing-input:checked + .billing-switch .knob { transform: translateX(100%); }
  .billing-switch .opt-m { color: #fff; }
  .billing-input:checked + .billing-switch .opt-m { color: var(--text-secondary); }
  .billing-input:checked + .billing-switch .opt-y { color: #fff; }
  .save { font-size: .72rem; background: var(--brass); color: #fff; padding: .1rem .45rem; border-radius: 999px; margin-left: .3rem; }

  /* Par défaut (mensuel) : on masque l'annuel. Coché : inverse (CSS :has(),
     zéro JS). Sans JS ni :has(), le défaut mensuel s'affiche correctement. */
  .amount-y, .plan-note-y { display: none; }
  #tarifs:has(.billing-input:checked) .amount-m { display: none; }
  #tarifs:has(.billing-input:checked) .amount-y { display: inline; }
  #tarifs:has(.billing-input:checked) .plan-note-y { display: block; }

  .grid-plans { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; max-width: 780px; margin-inline: auto; }
  @media (max-width: 720px) { .grid-plans { grid-template-columns: 1fr; } }
  .plan { display: flex; flex-direction: column; }
  .plan-hl { border-color: var(--brass); border-width: 2px; }
  .plan-badge { align-self: flex-start; background: var(--brass); color: #fff; font-size: .74rem; font-weight: 700;
    padding: .2rem .6rem; border-radius: 999px; margin-bottom: .5rem; }
  .plan-name { font-size: 1.4rem; }
  .plan-tag { min-height: 2.8em; }
  .plan-price { margin: .5rem 0 .25rem; }
  .plan-price .amount { font-size: 2.5rem; font-weight: 800; color: var(--ink); }
  .plan-price .per { color: var(--text-muted); font-weight: 600; margin-left: .25rem; }
  .plan-note { font-size: .82rem; color: var(--text-muted); min-height: 1.2em; margin-top: 0; }
  .plan-cta { margin-top: 1.25rem; justify-content: center; }
  .tarifs-foot { text-align: center; color: var(--text-muted); font-size: .9rem; margin-top: 1.5rem; }

  .faq-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 2rem; }
  @media (max-width: 760px) { .faq-list { grid-template-columns: 1fr; } }
  .faq-item h3 { margin-bottom: .35rem; }

  .cta-final { background: var(--ink); text-align: center; }
  .cta-final h2 { color: #fff; margin-bottom: 1.5rem; }
</style>
