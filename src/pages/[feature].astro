---
import Base from "../layouts/Base.astro";
import AppMockup from "../components/AppMockup.astro";
import { SITE } from "../config/site";
import { FEATURES } from "../content/features";

export function getStaticPaths() {
  return FEATURES.map((f) => ({ params: { feature: f.slug }, props: { f } }));
}

const { f } = Astro.props;
const url = new URL(`/${f.slug}`, SITE.url).href;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: f.faq.map((q) => ({
    "@type": "Question", name: q.q,
    acceptedAnswer: { "@type": "Answer", text: q.a },
  })),
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Fonctionnalités", item: new URL("/#fonctionnalites", SITE.url).href },
    { "@type": "ListItem", position: 3, name: f.navLabel, item: url },
  ],
};

// Maillage : les autres fonctionnalités.
const others = FEATURES.filter((x) => x.slug !== f.slug);
---
<Base title={f.title} description={f.metaDescription} path={`/${f.slug}`}>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />

  <section class="hero">
    <div class="container hero-grid">
      <div>
        <nav class="crumbs" aria-label="Fil d'Ariane"><a href="/">Accueil</a> <span>/</span> <a href="/#fonctionnalites">Fonctionnalités</a></nav>
        <p class="eyebrow">{f.keyword}</p>
        <h1>{f.h1}</h1>
        <p class="lead">{f.lead}</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={SITE.appUrl}>Essayer gratuitement</a>
          <a class="btn btn-ghost" href="/tarifs">Voir les tarifs</a>
        </div>
      </div>
      <AppMockup active={f.mockup.module} heading={f.mockup.heading} rows={f.mockup.rows} />
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Ce que ça change pour vous</h2>
      <div class="grid-3">
        {f.benefits.map((b) => (
          <div class="card"><h3>{b.t}</h3><p>{b.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="steps-sec">
    <div class="container">
      <h2>Comment ça marche</h2>
      <ol class="steps">
        {f.steps.map((s, i) => (
          <li><span class="step-n">{i + 1}</span><div><h3>{s.t}</h3><p>{s.d}</p></div></li>
        ))}
      </ol>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2>Questions fréquentes</h2>
      <div class="faq-list">
        {f.faq.map((q) => (
          <div class="faq-item"><h3>{q.q}</h3><p>{q.a}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="others">
    <div class="container">
      <h2>Explorer les autres fonctionnalités</h2>
      <div class="others-links">
        {others.map((o) => <a href={`/${o.slug}`} class="others-link">{o.navLabel}</a>)}
      </div>
    </div>
  </section>

  <section class="cta-final">
    <div class="container">
      <h2>Prêt à essayer {f.navLabel.toLowerCase()} ?</h2>
      <a class="btn btn-primary" href={SITE.appUrl}>Essayer gratuitement</a>
    </div>
  </section>
</Base>

<style>
  .hero { background: linear-gradient(180deg, #fff 0%, var(--cream) 100%); }
  .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 3rem; align-items: center; }
  @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } }
  .crumbs { font-size: .85rem; color: var(--text-muted); margin-bottom: .75rem; }
  .crumbs a { color: var(--text-muted); } .crumbs span { margin: 0 .35rem; }
  .hero-cta { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 1.5rem; }
  @media (max-width: 860px) { .grid-3 { grid-template-columns: 1fr; } }
  .steps-sec { background: #fff; }
  .steps { list-style: none; padding: 0; margin: 1.5rem 0 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 860px) { .steps { grid-template-columns: 1fr; } }
  .steps li { display: flex; gap: .9rem; align-items: flex-start; }
  .step-n { flex: none; width: 34px; height: 34px; border-radius: 50%; background: var(--ink); color: #fff;
    display: grid; place-items: center; font-weight: 800; }
  .faq-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.5rem; }
  @media (max-width: 760px) { .faq-list { grid-template-columns: 1fr; } }
  .faq-item h3 { margin-bottom: .35rem; }
  .others { background: var(--cream); }
  .others-links { display: flex; flex-wrap: wrap; gap: .6rem; margin-top: 1rem; }
  .others-link { background: #fff; border: 1px solid var(--border); border-radius: 999px; padding: .5rem 1rem; font-weight: 600; }
  .cta-final { background: var(--ink); text-align: center; }
  .cta-final h2 { color: #fff; margin-bottom: 1.5rem; }
</style>
