---
import Base from "../../layouts/Base.astro";
import { SITE } from "../../config/site";
import { SEGMENTS, profils, secteurs } from "../../content/segments";

export function getStaticPaths() {
  return SEGMENTS.map((s) => ({ params: { segment: s.slug }, props: { s } }));
}
const { s } = Astro.props;
const url = new URL(`/pour/${s.slug}`, SITE.url).href;

const faqLd = {
  "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: s.faq.map((q) => ({ "@type": "Question", name: q.q, acceptedAnswer: { "@type": "Answer", text: q.a } })),
};
const breadcrumbLd = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: SITE.url },
    { "@type": "ListItem", position: 3, name: s.navLabel, item: url },
  ],
};
const otherProfils = profils().filter((x) => x.slug !== s.slug);
const otherSecteurs = secteurs().filter((x) => x.slug !== s.slug);
---
<Base title={s.title} description={s.metaDescription} path={`/pour/${s.slug}`}>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />

  <section class="hero">
    <div class="container" style="max-width:760px;">
      <nav class="crumbs" aria-label="Fil d'Ariane"><a href="/">Accueil</a></nav>
      <p class="eyebrow">{s.kind === "secteur" ? "Par secteur" : "Par profil"}</p>
      <h1>{s.h1}</h1>
      <p class="lead">{s.lead}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={SITE.appUrl}>Essayer gratuitement</a>
        <a class="btn btn-ghost" href="/tarifs">Voir les tarifs</a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid-3">
        {s.points.map((p) => (
          <div class="card"><h3>{p.t}</h3><p>{p.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2>Questions fréquentes</h2>
      <div class="faq-list">
        {s.faq.map((q) => (
          <div class="faq-item"><h3>{q.q}</h3><p>{q.a}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="others">
    <div class="container">
      <h2>Stela s'adapte à votre situation</h2>
      <div class="others-links">
        {[...otherProfils, ...otherSecteurs].map((o) => (
          <a href={`/pour/${o.slug}`} class="others-link">{o.navLabel}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-final">
    <div class="container">
      <h2>Prêt à faire grandir votre réputation ?</h2>
      <a class="btn btn-primary" href={SITE.appUrl}>Essayer gratuitement</a>
    </div>
  </section>
</Base>

<style>
  .hero { background: linear-gradient(180deg, #fff 0%, var(--cream) 100%); }
  .crumbs { font-size: .85rem; color: var(--text-muted); margin-bottom: .75rem; }
  .crumbs a { color: var(--text-muted); }
  .hero-cta { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 860px) { .grid-3 { grid-template-columns: 1fr; } }
  .faq-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.5rem; }
  @media (max-width: 760px) { .faq-list { grid-template-columns: 1fr; } }
  .faq-item h3 { margin-bottom: .35rem; }
  .others { background: var(--cream); }
  .others-links { display: flex; flex-wrap: wrap; gap: .6rem; margin-top: 1rem; }
  .others-link { background: #fff; border: 1px solid var(--border); border-radius: 999px; padding: .5rem 1rem; font-weight: 600; }
  .cta-final { background: var(--ink); text-align: center; }
  .cta-final h2 { color: #fff; margin-bottom: 1.5rem; }
</style>
